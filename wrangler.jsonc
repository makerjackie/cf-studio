{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "cfdesk",
  "main": "workers/cfdesk-site.js",
  "compatibility_date": "2026-05-30",
  "assets": {
    "directory": "./site",
    "binding": "ASSETS"
  },
  "routes": [
    {
      "pattern": "cfdesk.01mvp.com",
      "custom_domain": true
    }
  ]
}
